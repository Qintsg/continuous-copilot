{
	"mcpServers": {
		"context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@upstash/context7-mcp@1.0.31"
			],
			"env": {
				"CONTEXT7_API_KEY": "在此处填入你的context7 api-key"
			}
		},
		"dida365": {
			"type": "http",
			"url": "https://mcp.dida365.com/"
		},
		"exa": {
			"type": "http",
			"url": "https://mcp.exa.ai/mcp"
		},
		"fetch": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"mcp-server-fetch"
			],
			"env": {
				"PYTHONIOENCODING": "utf-8"
			}
		},
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"E:/",
				"C:/",
				"D:/"
			]
		},
		"interactive-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"interactive-mcp",
				"-t",
				"86400",
				"--disable-tools",
				"message_complete_notification"
			]
		},
		"memory": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-memory"
			],
			"env": {
				"MEMORY_FILE_PATH": "C:/Users/qinta/.mcp/data/memory.jsonl"
			}
		},
		"sequential_thinking": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		}
	}
}